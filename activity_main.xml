<?xml version="1.0" encoding="utf-8"?>
<TableLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:layout_marginTop="50dp"
    android:layout_marginLeft="10dp"
    android:stretchColumns="0"
    >

    <TableRow
        android:layout_height="400dp"
        android:layout_width="match_parent"
        >

        <EditText
            android:layout_width="00dp"
            android:layout_height="wrap_content"
            />
    </TableRow>
    <TableRow
        >
    <Button
        android:layout_height="80dp"
        android:layout_width="wrap_content"
        android:layout_margin="5dp"
        android:text="AC"
        android:textSize="30dp"
        android:backgroundTint="#FFAC1C"
        />
    <Button
        android:layout_width="wrap_content"
        android:layout_height="80dp"
        android:layout_margin="5dp"
        android:text="()"
        android:textSize="30dp"
        android:backgroundTint="#7733FF"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:text="%"
            android:textSize="30dp"
            android:backgroundTint="#7733FF"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:text="/"
            android:textSize="30dp"
            android:backgroundTint="#7733FF"/>
    </TableRow>
    <TableRow
        >
        <Button
            android:layout_height="80dp"
            android:layout_width="wrap_content"
            android:layout_margin="5dp"
            android:text="7"
            android:textSize="30dp"
            android:backgroundTint="#BFF83A"
            android:textColor="#7733FF"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:text="6"
            android:textSize="30dp"
            android:backgroundTint="#BFF83A"
            android:textColor="#7733FF"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:text="5"
            android:textSize="30dp"
            android:backgroundTint="#BFF83A"
            android:textColor="#7733FF"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:text="X"
            android:textSize="30dp"/>
    </TableRow>
    <TableRow
        >
        <Button
            android:layout_height="80dp"
            android:layout_width="wrap_content"
            android:layout_margin="5dp"
            android:text="4"
            android:textSize="30dp"
            android:backgroundTint="#BFF83A"
            android:textColor="#7733FF"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:text="5"
            android:textSize="30dp"
            android:backgroundTint="#BFF83A"
            android:textColor="#7733FF"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:text="6"
            android:textSize="30dp"
            android:backgroundTint="#BFF83A"
            android:textColor="#7733FF"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:text="-"
            android:textSize="30dp"/>
    </TableRow>
    <TableRow
        >
        <Button
            android:layout_height="80dp"
            android:layout_width="wrap_content"
            android:layout_margin="5dp"
            android:text="1"
            android:textSize="30dp"
            android:backgroundTint="#BFF83A"
            android:textColor="#7733FF"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:text="2"
            android:textSize="30dp"
            android:backgroundTint="#BFF83A"
            android:textColor="#7733FF"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:text="3"
            android:textSize="30dp"
            android:backgroundTint="#BFF83A"
            android:textColor="#7733FF"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:text="+"
            android:textSize="30dp"/>
    </TableRow>
    <TableRow
        >
        <Button
            android:layout_height="80dp"
            android:layout_width="wrap_content"
            android:layout_margin="5dp"
            android:text="0"
            android:textSize="30dp"
            android:backgroundTint="#BFF83A"
            android:textColor="#7733FF"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:text="."
            android:textSize="30dp"
            android:backgroundTint="#BFF83A"
            android:textColor="#7733FF"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:text="B"
            android:textSize="30dp"
            android:backgroundTint="#BFF83A"
            android:textColor="#7733FF"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_margin="5dp"
            android:text="="
            android:textSize="30dp"
            android:textSize="30dp"
            android:backgroundTint="#FFAC1C"/>
    </TableRow>


</TableLayout>